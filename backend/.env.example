# Server
PORT=5000
NODE_ENV=production

# Database (Railway MySQL service)
DB_HOST=mysql.railway.internal
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=vexa_db

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=24h

# File uploads
UPLOAD_PATH=uploads
MAX_FILE_SIZE=5242880

# CORS - Frontend URL (Railway domain)
CORS_ORIGIN=https://vexa-frontend-production.up.railway.app
